---
/*
  SHOW DETAIL PAGE  ( /shows/<slug> )
 
  This is a dynamic page: Astro builds one HTML page for each
  file in src/content/shows/ at build time. The list of pages
  comes from getStaticPaths() below.
*/
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import donatePage from "../../content/settings/donate-page.json";
import showsPage from "../../content/settings/shows-page.json";

// Global ticket-fee notice (CMS-editable, one place, applies everywhere
// tickets are sold). Empty-safe: renders nothing when blank.
const ticketFeeNotice = (showsPage as any).ticket_fee_notice || "";

// "Sponsor This Show" routes straight to the hosted Soapbox donation page,
// the same link the Ways to Support page uses (CMS-editable, with the
// standard Soapbox URL as a safe fallback if the field is empty).
const sponsorUrl =
  donatePage.soapbox_donate_url || "https://pyt.secure.nonprofitsoapbox.com/donate";
 
export async function getStaticPaths() {
  const shows = await getCollection("shows");
  return shows.map((show) => ({
    params: { slug: show.id },
    props: { show },
  }));
}
 
const { show } = Astro.props;
const { Content } = await render(show);
const data = show.data;
 
// Audition window: end date drives auto-close (legacy single date as fallback).
const auditionEnd = data.audition_end ?? data.audition_date;
const auditionsClosed = auditionEnd && auditionEnd.getTime() < new Date().getTime();
 
// Double-cast performance schedule. Any show CAN be double cast (Mainstage
// always is; SecondStage/Studio sometimes are). When it is, the external
// ticketing site won't label which cast plays which date — so we list it here.
// Keep only rows that have at least a date and a cast (the two things a buyer
// needs to identify their performance); a stray half-filled row is dropped
// rather than rendered blank. The block shows ONLY when the show is marked
// double cast AND at least one valid row exists — so non-double-cast shows,
// and double-cast shows with nothing entered yet, show nothing.
const performances = (data.performances ?? []).filter(
  (p) => p && p.date_label && p.cast
);
const hasSchedule = data.double_cast === true && performances.length > 0;
---
 
<BaseLayout
  title={`${data.title} — Peninsula Youth Theatre`}
  description={data.synopsis?.split("\n")[0] || `${data.title} at Peninsula Youth Theatre`}
>
  <article class="show-detail">
    <div class="container show-grid">
      <!-- Poster column -->
      <div
        class="show-poster-large"
        style={data.poster ? `background-image: url(${data.poster}); background-size: cover; background-position: center;` : ""}
      >
        {!data.poster && (
          <span class="poster-placeholder-large">{data.title}</span>
        )}
      </div>
 
      <!-- Info column -->
      <div class="show-content">
        {data.eyebrow && <p class="eyebrow">{data.eyebrow}</p>}
        <h1>{data.title}</h1>
 
        <dl class="show-info-grid">
          <div>
            <dt>Dates</dt>
            <dd>{data.date_display}</dd>
          </div>
          <div>
            <dt>Venue</dt>
            <dd>{data.venue}</dd>
          </div>
          {data.runtime_minutes && (
            <div>
              <dt>Runtime</dt>
              <dd>About {data.runtime_minutes} minutes</dd>
            </div>
          )}
          {data.ages && (
            <div>
              <dt>Ages</dt>
              <dd>{data.ages}</dd>
            </div>
          )}
          {data.audition_display && !auditionsClosed && (
            <div>
              <dt>Auditions</dt>
              <dd>{data.audition_display}</dd>
            </div>
          )}
        </dl>
 
        <div class="show-ctas">
          {hasSchedule ? (
            <a href="#cast-schedule" class="btn btn-primary">
              Buy Tickets
            </a>
          ) : data.ticketing_url ? (
            <a href={data.ticketing_url} class="btn btn-primary" target="_blank" rel="noopener">
              Buy Tickets
            </a>
          ) : (
            <span class="btn btn-outline btn-disabled" aria-disabled="true">
              Tickets coming soon
            </span>
          )}
          {data.audition_url && (
            auditionsClosed ? (
              <span class="btn btn-outline btn-disabled" aria-disabled="true">
                Auditions closed
              </span>
            ) : (
              <a href={data.audition_url} class="btn btn-outline" target="_blank" rel="noopener">
                Auditions
              </a>
            )
          )}
          <a href={sponsorUrl} class="btn btn-outline" target="_blank" rel="noopener">
            Sponsor This Show
          </a>
          {data.cast_page_url && (
            <a href={data.cast_page_url} class="btn btn-outline">
              Cast Page
            </a>
          )}
        </div>

        {ticketFeeNotice && <p class="ticket-fee-notice">{ticketFeeNotice}</p>}
 
        <div class="show-synopsis">
          {data.synopsis.split("\n\n").map((para) => (
            <p>{para}</p>
          ))}
        </div>
 
        {hasSchedule && (
          <section id="cast-schedule" class="cast-schedule" aria-labelledby="cast-schedule-heading">
            <h2 id="cast-schedule-heading">Performances &amp; casts</h2>
            <p class="cast-schedule-note">
              Each performance is cast separately. Use the buttons below to
              buy tickets for the cast and date you'd like to see.
            </p>
            <ul class="perf-list">
              {performances.map((p) => (
                <li class="perf-row">
                  <div class="perf-when">
                    <span class="perf-date">{p.date_label}</span>
                    {p.time_label && <span class="perf-time">{p.time_label}</span>}
                  </div>
                  <span class="perf-cast">{p.cast}</span>
                  {p.buy_url ? (
                    <a href={p.buy_url} class="btn btn-primary perf-btn" target="_blank" rel="noopener">
                      Buy tickets
                    </a>
                  ) : (
                    <span class="btn btn-outline btn-disabled perf-btn" aria-disabled="true">
                      On sale soon
                    </span>
                  )}
                </li>
              ))}
            </ul>
            {ticketFeeNotice && <p class="ticket-fee-notice">{ticketFeeNotice}</p>}
          </section>
        )}
 
        <p class="back-link"><a href="/shows">← Back to all shows</a></p>
      </div>
    </div>
  </article>
</BaseLayout>
 
<style>
  .show-detail {
    padding-block: var(--space-xl);
  }
 
  .show-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
 
  .show-poster-large {
    aspect-ratio: 3 / 4;
    width: 100%;
    background: linear-gradient(150deg, var(--accent) 0%, var(--accent-deep) 100%);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    padding: var(--space-lg);
    box-shadow: var(--shadow-lift);
  }
 
  .poster-placeholder-large {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.05;
  }
 
  .show-content h1 {
    margin-block: 0.4rem var(--space-md);
  }
 
  .show-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    padding-block: var(--space-md);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
 
  .show-info-grid div {
    min-width: 0;
  }
 
  .show-info-grid dt {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.3rem;
  }
 
  .show-info-grid dd {
    font-size: 1rem;
    color: var(--ink);
    margin: 0;
  }
 
  .ticket-fee-notice {
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.5;
    max-width: 60ch;
    margin: var(--space-md) 0 var(--space-lg);
  }

  .show-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: var(--space-lg);
  }
 
  .btn-disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
 
  .show-synopsis p {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }
 
  .back-link {
    margin-top: var(--space-xl);
    font-size: 0.95rem;
  }
 
  .back-link a {
    color: var(--accent-deep);
  }
 
  /* --- Double-cast performance schedule --- */
  .cast-schedule {
    scroll-margin-top: 6rem;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }
 
  .cast-schedule h2 {
    margin: 0 0 0.4rem;
  }
 
  .cast-schedule-note {
    color: var(--ink-muted);
    font-size: 0.95rem;
    margin: 0 0 var(--space-md);
  }
 
  .perf-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
 
  .perf-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    padding: 0.8rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface, #fff);
  }
 
  .perf-when {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1 1 9rem;
  }
 
  .perf-date {
    font-weight: 600;
    color: var(--ink);
  }
 
  .perf-time {
    font-size: 0.9rem;
    color: var(--ink-muted);
  }
 
  .perf-cast {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--accent-deep);
    flex: 1 1 7rem;
  }
 
  .perf-btn {
    flex: 0 0 auto;
    margin-left: auto;
  }
 
  @media (max-width: 520px) {
    .perf-btn {
      margin-left: 0;
      width: 100%;
      text-align: center;
    }
  }
 
  /* Wider screens: poster beside content */
  @media (min-width: 920px) {
    .show-grid {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-2xl);
    }
    .show-poster-large {
      flex: 1;
      position: sticky;
      top: 80px;
      max-width: 380px;
    }
    .show-content {
      flex: 1.4;
    }
  }
</style>
