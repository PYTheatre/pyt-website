---
/*
  COMBINED SHOWS PAGE  ( /shows )

  The "everything" page reached by the main Shows menu title.
  Merges three production types into ONE list, sorted by date:
    - Musicals          (shows tagged production_type: Musical)
    - Studio Productions (shows tagged production_type: Studio Production)
    - Stories on Stage   (the separate storiesOnStage collection)

  Each card shows a small coloured type label. Musicals and Studio
  Productions link to their own detail page (/shows/<id>); Stories on
  Stage cards link across to the /stories-on-stage page (chosen by PM —
  Stories productions have no individual detail pages).
*/
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { getCollection } from "astro:content";
import pageContent from "../../content/settings/shows-page.json";

// Pull both collections and normalise them into one shape we can sort
// and render together. `kind` drives the label + where the card links.
const shows = await getCollection("shows");
const stories = await getCollection("storiesOnStage");

const combined = [
  ...shows.map((s) => ({
    title: s.data.title,
    date_display: s.data.date_display,
    start: s.data.start_date.getTime(),
    poster: s.data.poster,
    kind: s.data.production_type, // "Musical" | "Studio Production"
    href: `/shows/${s.id}`,
    external: false,
  })),
  ...stories.map((p) => ({
    title: p.data.title,
    date_display: p.data.date_display,
    start: p.data.start_date.getTime(),
    poster: p.data.poster,
    kind: "Stories on Stage",
    href: `/stories-on-stage/${p.id}`,
    external: false,
  })),
].sort((a, b) => a.start - b.start);

// Map each kind to its label CSS class.
const kindClass = (kind: string) =>
  kind === "Studio Production"
    ? "label-studio"
    : kind === "Stories on Stage"
    ? "label-stories"
    : "label-musical";
---

<BaseLayout
  title="Shows — Peninsula Youth Theatre"
  description="The full Peninsula Youth Theatre season — Musicals, Studio Productions, and Stories on Stage, in date order."
>
  <PageHero
    eyebrow={pageContent.eyebrow}
    title={pageContent.title}
  />

  <section class="section show-list-section">
    <div class="container">
      {combined.length === 0 ? (
        <p class="empty-state">No shows announced yet. Check back soon.</p>
      ) : (
        <ul class="combined-list">
          {combined.map((item) => (
            <li class="combined-row">
              <a href={item.href} class="combined-card">
                <div
                  class="combined-poster"
                  style={item.poster ? `background-image: url(${item.poster}); background-size: cover; background-position: center;` : ""}
                >
                  {!item.poster && <span class="poster-placeholder">{item.title}</span>}
                </div>
                <div class="combined-info">
                  <span class={`type-label ${kindClass(item.kind)}`}>{item.kind}</span>
                  <h2>{item.title}</h2>
                  <p class="combined-dates">
                    {item.date_display}
                    {item.kind === "Stories on Stage" ? (
                      <span class="cross-link"> · tickets &amp; bookings →</span>
                    ) : (
                      <span class="cross-link"> · tickets &amp; details →</span>
                    )}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .show-list-section {
    padding-top: 0;
  }

  .combined-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .combined-row {
    margin: 0;
  }

  .combined-card {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: var(--space-md);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .combined-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .combined-poster {
    flex: 0 0 96px;
    align-self: stretch;
    background: linear-gradient(150deg, var(--accent) 0%, var(--accent-deep) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    padding: 0.5rem;
  }

  .poster-placeholder {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.1;
  }

  .combined-info {
    padding: var(--space-md) var(--space-md) var(--space-md) 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .type-label {
    display: inline-block;
    width: fit-content;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.18rem 0.5rem;
    border-radius: var(--radius-pill);
    margin-bottom: 0.35rem;
  }

  .label-musical {
    color: var(--accent-deep);
    background: var(--accent-soft);
  }

  .label-studio {
    color: #27500a;
    background: #eaf3de;
  }

  .label-stories {
    color: #0c447c;
    background: #e6f1fb;
  }

  .combined-info h2 {
    font-size: 1.35rem;
    margin: 0 0 0.25rem;
  }

  .combined-dates {
    font-size: 0.95rem;
    color: var(--ink);
    font-weight: 500;
    margin: 0;
  }

  .cross-link {
    color: var(--accent-deep);
    font-weight: 500;
  }

  .empty-state {
    padding: var(--space-lg);
    text-align: center;
    color: var(--ink-muted);
  }

  @media (min-width: 720px) {
    .combined-poster {
      flex: 0 0 140px;
    }
    .combined-info h2 {
      font-size: 1.6rem;
    }
  }
</style>
