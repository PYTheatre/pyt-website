---
/*
  SPONSORSHIP PAGE  ( /sponsor )

  Content from src/content/settings/sponsorship-page.json.

  Show-aware behavior:
    When someone arrives from a specific show page, the URL looks like
    /sponsor?show=dragons-love-tacos. A small client-side script reads
    the parameter, looks up the matching show title from the shows
    collection (embedded as JSON below), and:
      1. Updates the page heading to acknowledge the show
      2. Adds the show name as a "?show=<slug>" parameter to every
         show-tier donation URL, so when it eventually points to
         Soapbox the show name carries through

  Sponsorship is presented as distinct from regular donations — different
  page, different language, different layout — per the locked decision.
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getCollection } from "astro:content";
import sponsor from "../content/settings/sponsorship-page.json";

// Build a slug→title lookup for the client-side script.
// (We can't read URL params at build time on a static site,
//  so the client JS handles the show-aware bit at view time.)
const shows = await getCollection("shows");
const showLookup = Object.fromEntries(shows.map((s) => [s.id, s.data.title]));
const showLookupJson = JSON.stringify(showLookup);
---

<BaseLayout
  title={`${sponsor.title} — Peninsula Youth Theatre`}
  description="Sponsor a Peninsula Youth Theatre Mainstage show or our full season. Recognition options for businesses, foundations, and individual supporters."
>
  <PageHero
    eyebrow={sponsor.eyebrow}
    title={sponsor.title}
  />

  <!-- Optional "sponsoring X show" banner, filled in by the client-side script -->
  <section class="show-context" id="show-context" hidden>
    <div class="container">
      <p>You're sponsoring: <strong id="show-context-name"></strong></p>
    </div>
  </section>

  <section class="section sponsor-intro">
    <div class="container">
      <h2 class="intro-heading">{sponsor.intro_heading}</h2>
      <div class="intro-body">
        {sponsor.intro_body.split("\n\n").map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- ============ SHOW TIERS ============ -->
  <section class="section tier-section" id="show">
    <div class="container">
      <p class="tier-eyebrow">Show-level sponsorship</p>
      <h2 class="section-head">{sponsor.show_tiers_heading}</h2>
      <p class="tier-blurb">{sponsor.show_tiers_blurb}</p>

      <ul class="tier-list">
        {sponsor.show_tiers.map((tier) => (
          <li class="tier-card" data-tier-group="show">
            <div class="tier-header">
              <p class="tier-amount">{tier.amount}</p>
              <h3 class="tier-name">{tier.name}</h3>
            </div>
            <p class="tier-description">{tier.description}</p>
            <ul class="tier-benefits">
              {tier.benefits.map((b) => <li>{b}</li>)}
            </ul>
            <div class="tier-cta">
              {tier.donation_url ? (
                <a
                  href={tier.donation_url}
                  class="btn btn-primary tier-button"
                  data-base-url={tier.donation_url}
                  target="_blank"
                  rel="noopener"
                >
                  Give at this level
                </a>
              ) : (
                <a
                  href={`mailto:${sponsor.contact_email}?subject=${encodeURIComponent("Sponsorship inquiry: " + tier.name)}`}
                  class="btn btn-outline tier-button-inquire"
                  data-tier={tier.name}
                  data-tier-group="show"
                >
                  Inquire about this level
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ SEASON TIERS ============ -->
  <section class="section tier-section season-section" id="season">
    <div class="container">
      <p class="tier-eyebrow">Season-level sponsorship</p>
      <h2 class="section-head">{sponsor.season_tiers_heading}</h2>
      <p class="tier-blurb">{sponsor.season_tiers_blurb}</p>

      <ul class="tier-list">
        {sponsor.season_tiers.map((tier) => (
          <li class="tier-card" data-tier-group="season">
            <div class="tier-header">
              <p class="tier-amount">{tier.amount}</p>
              <h3 class="tier-name">{tier.name}</h3>
            </div>
            <p class="tier-description">{tier.description}</p>
            <ul class="tier-benefits">
              {tier.benefits.map((b) => <li>{b}</li>)}
            </ul>
            <div class="tier-cta">
              {tier.donation_url ? (
                <a
                  href={tier.donation_url}
                  class="btn btn-primary"
                  target="_blank"
                  rel="noopener"
                >
                  Give at this level
                </a>
              ) : (
                <a
                  href={`mailto:${sponsor.contact_email}?subject=${encodeURIComponent("Sponsorship inquiry: " + tier.name)}`}
                  class="btn btn-outline"
                >
                  Inquire about this level
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section class="section contact-section">
    <div class="container contact-inner">
      <h2 class="section-head">Let's talk.</h2>
      <p class="contact-blurb">{sponsor.contact_blurb}</p>
      <a
        href={`mailto:${sponsor.contact_email}?subject=${encodeURIComponent("Sponsorship inquiry")}`}
        class="btn btn-primary"
      >
        Email {sponsor.contact_email}
      </a>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ showLookup: showLookupJson }}>
  // Show-aware behavior: read ?show=<slug> from the URL, look up the
  // show's title, update the banner and the show-tier donation URLs.
  (function () {
    const params = new URLSearchParams(window.location.search);
    const slug = params.get("show");
    if (!slug) return;

    const lookup = JSON.parse(showLookup);
    const title = lookup[slug];
    if (!title) return; // Unknown slug — silently ignore

    // 1) Show the banner.
    const banner = document.getElementById("show-context");
    const nameEl = document.getElementById("show-context-name");
    if (banner && nameEl) {
      nameEl.textContent = title;
      banner.hidden = false;
    }

    // 2) Add ?show=<slug> to every show-tier "Give at this level" URL.
    document
      .querySelectorAll('.tier-card[data-tier-group="show"] a[data-base-url]')
      .forEach((link) => {
        const base = link.getAttribute("data-base-url");
        if (!base) return;
        const sep = base.includes("?") ? "&" : "?";
        link.setAttribute("href", `${base}${sep}show=${encodeURIComponent(slug)}`);
      });

    // 3) Update mailto subjects on show-tier "Inquire" buttons to mention the show.
    document
      .querySelectorAll('.tier-card[data-tier-group="show"] a[data-tier]')
      .forEach((link) => {
        const tier = link.getAttribute("data-tier");
        const subject = `Sponsorship inquiry: ${tier} for ${title}`;
        link.setAttribute(
          "href",
          `mailto:${link.getAttribute("href").split("?")[0].replace("mailto:", "")}` +
            `?subject=${encodeURIComponent(subject)}`
        );
      });
  })();
</script>

<style>
  /* ---- Show context banner ---- */
  .show-context {
    background: var(--accent-soft);
    border-bottom: 1px solid var(--accent);
    padding-block: var(--space-sm);
  }
  .show-context p {
    margin: 0;
    color: var(--accent-deep);
    font-weight: 500;
    font-size: 0.95rem;
  }

  /* ---- Intro ---- */
  .sponsor-intro {
    padding-block: var(--space-md) var(--space-lg);
  }
  .intro-heading {
    font-size: clamp(1.4rem, 3.5vw, 1.9rem);
    max-width: 28ch;
    margin-bottom: var(--space-md);
  }
  .intro-body {
    max-width: 62ch;
  }
  .intro-body p {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: var(--space-sm);
  }

  /* ---- Tier sections ---- */
  .tier-section {
    padding-block: var(--space-xl);
  }
  .season-section {
    background: var(--paper-warm);
    border-block: 1px solid var(--line);
  }
  .tier-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }
  .section-head {
    margin-block: 0.4rem var(--space-sm);
    max-width: 22ch;
  }
  .tier-blurb {
    max-width: 62ch;
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }

  /* ---- Tier cards ---- */
  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .tier-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }

  .tier-header {
    margin-bottom: var(--space-sm);
  }
  .tier-amount {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--accent);
    line-height: 1.1;
  }
  .tier-name {
    font-size: 1.1rem;
    margin-top: 0.2rem;
  }

  .tier-description {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-sm);
  }

  .tier-benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md);
    flex-grow: 1;
  }
  .tier-benefits li {
    position: relative;
    padding-left: 1.3rem;
    margin-bottom: 0.45rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .tier-benefits li::before {
    content: "";
    position: absolute;
    left: 0.1rem;
    top: 0.65rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--accent);
  }

  .tier-cta {
    margin-top: auto;
  }
  .tier-cta .btn {
    width: 100%;
    text-align: center;
    justify-content: center;
  }

  /* ---- Contact section ---- */
  .contact-section {
    padding-block: var(--space-2xl);
    background: var(--ink);
    color: #fff;
  }
  .contact-inner {
    max-width: 56ch;
  }
  .contact-section h2 {
    color: #fff;
    margin-bottom: var(--space-md);
  }
  .contact-blurb {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  /* ---- Wider screens ---- */
  @media (min-width: 720px) {
    .tier-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .tier-list {
      grid-template-columns: repeat(4, 1fr);
    }
    /* season tiers are 3 — center them */
    .season-section .tier-list {
      grid-template-columns: repeat(3, 1fr);
      max-width: 900px;
    }
  }
</style>
