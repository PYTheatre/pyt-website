---
/*
  RENTALS PAGE  ( /rentals )

  Three parts:
  1. Hero intro.
  2. A grid of rental categories — each a card with a photo, name,
     and description. Staff add/remove/reorder these and swap photos
     via the CMS (Site Settings → Rentals Page). The whole section
     hides if there are no categories.
  3. An inquiry form (name, email, what they're looking for, preferred
     dates) that submits to Formspree, which emails the inquiry to
     PYT's inboxes.

  PHOTO HANDLING NOTE:
  Category photos are expected to vary in quality over time. To keep
  the page looking tidy regardless:
    - every photo sits in a fixed 4:3 frame and is cropped to fill it
      (object-fit: cover), so mismatched dimensions never break layout;
    - a subtle gradient overlay + rounded corners + soft shadow unify
      the cards visually;
    - images lazy-load and are display-capped so a huge unoptimized
      upload won't slow the page.

  FORM NOTE:
  The form posts to the Formspree endpoint stored in the CMS field
  `form_endpoint`. If that field is ever blank, the form is replaced
  with a plain mailto fallback so the page never shows a dead form.
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import page from "../content/settings/rentals-page.json";

const categories = page.categories || [];
const formEndpoint = page.form_endpoint || "";
---

<BaseLayout
  title={`${page.title} — Peninsula Youth Theatre`}
  description="Costume, prop, set, and furniture rentals from Peninsula Youth Theatre for schools and community theatres."
>
  <PageHero
    eyebrow={page.eyebrow}
    title={page.title}
    lede={page.intro}
  />

  {/* ============ CATEGORIES ============ */}
  {categories.length > 0 && (
    <section class="section categories-section">
      <div class="container">
        <h2 class="section-head">{page.categories_heading}</h2>
        {page.categories_blurb && <p class="section-blurb">{page.categories_blurb}</p>}

        <ul class="category-grid">
          {categories.map((cat: any) => (
            <li class="category-card">
              <div class="category-photo-frame">
                {cat.photo ? (
                  <img
                    src={cat.photo}
                    alt={cat.name}
                    class="category-photo"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="category-photo-placeholder">
                    <span>Photo coming soon</span>
                  </div>
                )}
              </div>
              <div class="category-body">
                <h3>{cat.name}</h3>
                {cat.description && <p>{cat.description}</p>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ============ INQUIRY FORM ============ */}
  <section class="section inquiry-section">
    <div class="container">
      <h2 class="section-head">{page.inquiry_heading}</h2>
      {page.inquiry_blurb && <p class="section-blurb">{page.inquiry_blurb}</p>}

      <div class="form-card">
        {formEndpoint ? (
          <form action={formEndpoint} method="POST" class="rental-form">
            <div class="field-group">
              <label for="name">Your name <span class="required-mark" aria-label="required">*</span></label>
              <input type="text" name="name" id="name" autocomplete="name" required />
            </div>

            <div class="field-group">
              <label for="email">Email address <span class="required-mark" aria-label="required">*</span></label>
              <input type="email" name="email" id="email" autocomplete="email" required />
            </div>

            <div class="field-group">
              <label for="organization">Organization (optional)</label>
              <input type="text" name="organization" id="organization" autocomplete="organization" />
            </div>

            <div class="field-group">
              <label for="looking_for">What are you looking for? <span class="required-mark" aria-label="required">*</span></label>
              <textarea name="looking_for" id="looking_for" rows="4" required
                placeholder="Tell us about your production and the costumes, props, sets, or furniture you need."></textarea>
            </div>

            <div class="field-group">
              <label for="preferred_dates">Preferred dates</label>
              <input type="text" name="preferred_dates" id="preferred_dates"
                placeholder="When do you need the items, and for how long?" />
            </div>

            {/* Sets the email subject line in PYT's inbox */}
            <input type="hidden" name="_subject" value="New rental inquiry from pytnet.org" />

            {/* Honeypot anti-spam field (hidden from real users) */}
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off"
              style="position:absolute;left:-5000px;" aria-hidden="true" />

            <div class="submit-row">
              <button type="submit" class="btn btn-primary">Send inquiry</button>
              <p class="submit-note">We typically reply within a few business days.</p>
            </div>
          </form>
        ) : (
          <div class="form-fallback">
            <p>To inquire about a rental, please email us at
              <a href="mailto:info@pytnet.org?subject=Rental%20inquiry"> info@pytnet.org</a>
              with details about your production and what you're looking for.</p>
            <a href="mailto:info@pytnet.org?subject=Rental%20inquiry" class="btn btn-primary">Email us</a>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-head {
    margin-block: 0.4rem var(--space-sm);
  }

  .section-blurb {
    max-width: 62ch;
    margin-bottom: var(--space-lg);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* ---- Category cards ---- */
  .category-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .category-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .category-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lift);
  }

  /* Fixed 4:3 frame keeps every card the same shape no matter the
     photo's real dimensions. The gradient overlay unifies uneven
     photos and keeps any future text legible. */
  .category-photo-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--paper-warm);
    overflow: hidden;
  }

  .category-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .category-photo-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.06) 100%);
    pointer-events: none;
  }

  .category-photo-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-family: var(--font-heading);
    font-size: 1rem;
  }

  .category-body {
    padding: var(--space-md);
  }

  .category-body h3 {
    margin-bottom: 0.5rem;
  }

  .category-body p {
    font-size: 0.96rem;
    line-height: 1.6;
  }

  /* ---- Inquiry section sits on the warm background to separate it ---- */
  .inquiry-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }

  .form-card {
    max-width: 640px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow-soft);
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: var(--space-md);
  }

  label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink);
  }

  .required-mark {
    color: var(--accent);
    margin-left: 0.15em;
  }

  input[type="text"],
  input[type="email"],
  textarea {
    width: 100%;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    background: var(--paper);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  textarea {
    resize: vertical;
    line-height: 1.5;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  ::placeholder {
    color: var(--ink-muted);
    opacity: 1;
  }

  .submit-row {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .submit-note {
    font-size: 0.82rem;
    color: var(--ink-muted);
  }

  .form-fallback p {
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .form-fallback a:not(.btn) {
    color: var(--accent-deep);
    text-decoration: underline;
  }

  /* ---- Larger screens ---- */
  @media (min-width: 720px) {
    .category-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    .submit-row {
      flex-direction: row;
      align-items: center;
    }
  }

  @media (min-width: 1024px) {
    .category-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
