---
/*
  CASTING PAGE  ( /casting )

  All content from src/content/settings/casting-page.json.
  Image-only page (per client request) — hero image at top, then
  body copy, then a pulled-out closing line, then a Shows CTA.

  The body field is stored as Markdown-ish text in the CMS.
  We parse it lightly here: blank lines = paragraph breaks,
  lines starting with "- " become a bulleted list.
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import casting from "../content/settings/casting-page.json";
import { renderMarkdown } from "../lib/markdown";

// The body field uses the CMS "markdown" widget, so it holds real Markdown
// (bold, italic, bullet lists, links). Render it to HTML here and inject it
// below with set:html, rather than printing the raw text.
const bodyHtml = renderMarkdown(casting.body);
---

<BaseLayout
  title={`${casting.title} — Peninsula Youth Theatre`}
  description="How Peninsula Youth Theatre approaches casting: ensemble-focused, equitable, and built around the experience of every young performer."
>
  <!-- Title block at top -->
  <section class="casting-title">
    <div class="container">
      {casting.eyebrow && <p class="eyebrow">{casting.eyebrow}</p>}
      <h1>{casting.title}</h1>
    </div>
  </section>

  <!-- Banner image (contained width, short strip) -->
  {casting.hero_image ? (
    <section class="casting-banner" aria-label="Casting banner image">
      <div class="container">
        <img src={casting.hero_image} alt="" class="casting-banner-img" loading="lazy" />
      </div>
    </section>
  ) : null}

  <!-- Body copy -->
  <section class="section casting-body">
    <div class="container casting-prose" set:html={bodyHtml} />
  </section>

  <!-- Pulled-out closing line -->
  {casting.closing_quote && (
    <section class="casting-quote-section">
      <div class="container">
        <blockquote class="casting-quote">
          <p>{casting.closing_quote}</p>
        </blockquote>
      </div>
    </section>
  )}

  <!-- CTA -->
  {casting.cta_url && casting.cta_label && (
    <section class="casting-cta-section">
      <div class="container">
        <a href={casting.cta_url} class="btn btn-primary">
          {casting.cta_label} →
        </a>
        <p class="casting-awards-link">
          Each show, we celebrate our performers with the
          <a href="/judy-robe-spirits-awards">Judy Robe &amp; Spirits Awards</a>.
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ---- Banner image (contained, short strip) ---- */
  .casting-banner {
    padding-top: var(--space-md);
  }

  .casting-banner-img {
    width: 100%;
    aspect-ratio: 21 / 6;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
    box-shadow: var(--shadow-soft);
  }

  /* ---- Title block ---- */
  .casting-title {
    padding-block: var(--space-xl) 0;
  }

  .casting-title h1 {
    margin-top: 0.5rem;
  }

  /* ---- Awards link under the CTA ---- */
  .casting-awards-link {
    margin-top: var(--space-md);
    font-size: 0.98rem;
    color: var(--ink-soft);
  }

  .casting-awards-link a {
    color: var(--accent-deep);
    text-decoration: underline;
  }

  /* ---- Body prose ---- */
  .casting-body {
    padding-block: var(--space-md) var(--space-lg);
  }

  .casting-prose {
    max-width: 68ch;
  }

  /* The body is injected via set:html (rendered Markdown), so its elements
     don't carry Astro's scoped attribute. Target them with :global within
     the scoped .casting-prose wrapper. */
  .casting-prose :global(p) {
    font-size: 1.08rem;
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }

  .casting-prose :global(strong) {
    font-weight: 700;
  }

  .casting-prose :global(em) {
    font-style: italic;
  }

  .casting-prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }

  .casting-prose :global(ul) {
    margin: var(--space-md) 0;
    padding-left: 0;
    list-style: none;
  }

  .casting-prose :global(li) {
    position: relative;
    padding-left: 1.6rem;
    margin-bottom: 0.7rem;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .casting-prose :global(li)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--accent);
  }

  /* ---- Pulled-out closing line ---- */
  .casting-quote-section {
    padding-block: var(--space-lg) var(--space-xl);
    background: var(--paper-warm);
    border-block: 1px solid var(--line);
  }

  .casting-quote {
    max-width: 56ch;
    margin: 0 auto;
    padding: 0;
  }

  .casting-quote p {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3.5vw, 1.9rem);
    line-height: 1.35;
    color: var(--ink);
    font-style: italic;
    text-align: center;
    font-weight: 500;
  }

  /* ---- CTA ---- */
  .casting-cta-section {
    padding-block: var(--space-xl);
    text-align: center;
  }

  @media (min-width: 720px) {
    .casting-banner-img {
      aspect-ratio: 24 / 5;
    }
  }
</style>
