---
/*
  ABOUT PAGE  ( /about )

  All content from src/content/settings/about-page.json.
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import about from "../content/settings/about-page.json";

// Split the story into paragraphs at blank lines.
const paragraphs = about.story.split("\n\n").filter((p) => p.trim().length > 0);

// Board members (optional — may not exist on older versions of the file).
// If the field is missing or the list is empty, the whole section is hidden.
const boardMembers = (about as any).board_members || [];
const boardHeading = (about as any).board_section_heading || "Board of Directors";
const boardBlurb = (about as any).board_section_blurb || "";

// Staff members (optional). Same shape and behavior as board members.
// Section sits ABOVE the Board section and hides if empty.
const staffMembers = (about as any).staff_members || [];
const staffHeading = (about as any).staff_section_heading || "Our Staff";
const staffBlurb = (about as any).staff_section_blurb || "";

// Optional banner image at the top of the page.
const bannerImage = (about as any).banner_image || "";

// Build initials for the placeholder avatar (when a member has no photo yet).
function getInitials(name: string): string {
  return name
    .trim()
    .split(/\s+/)
    .map((part) => part[0])
    .filter(Boolean)
    .slice(0, 2)
    .join("")
    .toUpperCase();
}
---

<BaseLayout title={`${about.title} — Peninsula Youth Theatre`}>
  <PageHero eyebrow={about.eyebrow} title={about.title} />

  {bannerImage && (
    <section class="about-banner" aria-label="About banner image">
      <div class="container">
        <img src={bannerImage} alt="" class="about-banner-img" loading="lazy" />
      </div>
    </section>
  )}

  <section class="section about-section">
    <div class="container about-grid">
      <div class="about-story">
        {paragraphs.map((p) => <p>{p}</p>)}
        <p class="about-awards-link">
          Learn about the <a href="/judy-robe-spirits-awards">Judy Robe &amp; Spirits Awards</a>,
          our tradition of celebrating outstanding performers each season.
        </p>
      </div>

      <aside class="contact-card" id="contact">
        <h2>Get in touch</h2>
        <dl>
          <div>
            <dt>Address</dt>
            <dd>{about.address}</dd>
          </div>
          <div>
            <dt>Phone</dt>
            <dd><a href={`tel:${about.phone.replace(/[^+\d]/g, "")}`}>{about.phone}</a></dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${about.email}`}>{about.email}</a></dd>
          </div>
          <div>
            <dt>Tax ID (EIN)</dt>
            <dd>{about.ein}</dd>
          </div>
        </dl>
        <p class="nonprofit-note">
          Peninsula Youth Theatre is a 501(c)(3) nonprofit corporation.
        </p>
      </aside>
    </div>
  </section>

  {staffMembers.length > 0 && (
    <section class="section staff-section">
      <div class="container">
        <p class="eyebrow">Our team</p>
        <h2 class="section-head">{staffHeading}</h2>
        {staffBlurb && <p class="board-blurb">{staffBlurb}</p>}

        <ul class="board-grid">
          {staffMembers.map((m: any) => (
            <li class="board-card">
              <div
                class="board-photo"
                style={m.photo ? `background-image: url(${m.photo}); background-size: cover; background-position: center;` : ""}
              >
                {!m.photo && (
                  <span class="board-initials">{getInitials(m.name)}</span>
                )}
              </div>
              <p class="board-pyt-title">{m.pyt_title}</p>
              <p class="board-name">{m.name}</p>
              {m.outside_title && (
                <p class="board-outside-title">{m.outside_title}</p>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {boardMembers.length > 0 && (
    <section class="section board-section">
      <div class="container">
        <p class="eyebrow">Leadership</p>
        <h2 class="section-head">{boardHeading}</h2>
        {boardBlurb && <p class="board-blurb">{boardBlurb}</p>}

        <ul class="board-grid">
          {boardMembers.map((m: any) => (
            <li class="board-card">
              <div
                class="board-photo"
                style={m.photo ? `background-image: url(${m.photo}); background-size: cover; background-position: center;` : ""}
              >
                {!m.photo && (
                  <span class="board-initials">{getInitials(m.name)}</span>
                )}
              </div>
              <p class="board-pyt-title">{m.pyt_title}</p>
              <p class="board-name">{m.name}</p>
              {m.outside_title && (
                <p class="board-outside-title">{m.outside_title}</p>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .about-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* ---- Banner image (contained, short strip) ---- */
  .about-banner {
    padding-top: var(--space-md);
  }

  .about-banner-img {
    width: 100%;
    aspect-ratio: 21 / 6;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
    box-shadow: var(--shadow-soft);
  }

  .about-awards-link {
    margin-top: var(--space-sm);
    font-size: 1.02rem;
  }

  .about-awards-link a {
    color: var(--accent-deep);
    text-decoration: underline;
  }

  /* ---- Staff section: plain paper so it reads distinct from the
          warm-background Board section directly beneath it ---- */
  .staff-section {
    padding-bottom: var(--space-lg);
  }

  .about-story p {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .contact-card {
    padding: var(--space-lg);
    background: var(--paper-warm);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .contact-card h2 {
    font-size: 1.3rem;
    margin-bottom: var(--space-md);
  }

  .contact-card dl {
    margin: 0;
  }

  .contact-card div {
    margin-bottom: var(--space-sm);
  }

  .contact-card dt {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.25rem;
  }

  .contact-card dd {
    font-size: 0.98rem;
    color: var(--ink);
    margin: 0;
  }

  .contact-card a {
    color: var(--accent-deep);
  }

  .contact-card a:hover {
    text-decoration: underline;
  }

  .nonprofit-note {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--line);
    font-size: 0.85rem;
    color: var(--ink-muted);
  }

  /* ---- Board of Directors section ---- */
  .board-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }

  .board-blurb {
    max-width: 60ch;
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }

  .board-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .board-card {
    text-align: left;
  }

  .board-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: linear-gradient(150deg, var(--accent) 0%, var(--accent-deep) 100%);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    margin-bottom: var(--space-sm);
    overflow: hidden;
  }

  .board-initials {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .board-pyt-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.2rem;
  }

  .board-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.15rem;
    line-height: 1.2;
  }

  .board-outside-title {
    font-size: 0.88rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.35;
  }

  @media (min-width: 720px) {
    .board-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .board-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 720px) {
    .about-banner-img {
      aspect-ratio: 24 / 5;
    }
  }

  @media (min-width: 920px) {
    .about-grid {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-2xl);
    }
    .about-story {
      flex: 2;
    }
    .contact-card {
      flex: 1;
      position: sticky;
      top: 80px;
      min-width: 280px;
    }
  }
</style>
