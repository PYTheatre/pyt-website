---
/*
  HOME PAGE.

  Content comes from two CMS-managed sources:
   - src/content/settings/home-page.json — all the editable copy
     (hero, optional hero banner photo, discovery cards, impact
     stats, section headings, etc.)
   - donation-campaign.json — the campaign progress numbers.

  Layout/structure lives here in code (not editable via CMS, by
  design — so the page can't be visually broken). All words, links,
  images, and numbers are editable through the CMS.
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import home from "../content/settings/home-page.json";
import campaign from "../content/settings/donation-campaign.json";

// --- Donation campaign numbers ---
const goal = campaign.goal_amount;
const raised = campaign.raised_amount;
const donorCount = campaign.donor_count;
const campaignLabel = campaign.campaign_label;
const pct = Math.round((raised / goal) * 100);

// --- Hero heading with optional italic word ---
// The CMS lets staff pick one word in the heading to italicize
// (the accent style). If that word appears in the heading, we
// split around it; otherwise the heading renders plain.
const heading = home.hero_heading;
const italicWord = home.hero_heading_italic_word?.trim();
let headingBefore = heading;
let headingItalic = "";
let headingAfter = "";
if (italicWord && heading.includes(italicWord)) {
  const idx = heading.indexOf(italicWord);
  headingBefore = heading.slice(0, idx);
  headingItalic = italicWord;
  headingAfter = heading.slice(idx + italicWord.length);
}

// --- Optional hero banner image ---
// A wide photo shown under the intro text. Hidden when empty.
const heroImage = (home as any).hero_image || "";
---

<BaseLayout title="Peninsula Youth Theatre — Outstanding youth theatre">
  <!-- ============ HERO (intro text) ============ -->
  <section class="hero">
    <div class="container">
      <div class="hero-copy">
        <p class="eyebrow">{home.hero_eyebrow}</p>
        <h1>{headingBefore}{headingItalic && <span class="accent-italic">{headingItalic}</span>}{headingAfter}</h1>
        <p class="hero-lede">{home.hero_lede}</p>
        <div class="hero-ctas">
          <a href={home.hero_primary_url} class="btn btn-primary">{home.hero_primary_label}</a>
          <a href={home.hero_secondary_url} class="btn btn-outline">{home.hero_secondary_label}</a>
        </div>
      </div>
    </div>

    <!-- Wide hero banner photo (hidden when no image is set) -->
    {heroImage && (
      <div class="container">
        <img src={heroImage} alt="" class="hero-banner-img" loading="eager" />
      </div>
    )}
  </section>

  <!-- ============ DISCOVERY CARDS ============ -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">{home.discovery_eyebrow}</p>
      <h2 class="section-head">{home.discovery_heading}</h2>

      <div class="card-grid">
        {home.discovery_cards.map((card) => (
          <a href={card.url} class="card">
            <p class="card-eyebrow">{card.eyebrow}</p>
            <h3>{card.title}</h3>
            <p class="card-body">{card.body}</p>
            <div class="card-meta">
              {card.meta.map((m) => <span>{m}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ IMPACT STATS ============ -->
  <section class="section impact">
    <div class="container">
      <p class="eyebrow">{home.impact_eyebrow}</p>
      <h2 class="section-head">{home.impact_heading}</h2>

      <div class="stat-grid">
        {home.stats.map((stat) => (
          <div class="stat">
            <p class="stat-figure">{stat.figure}</p>
            <p class="stat-label">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ DONATION TEASER ============ -->
  <section class="section donate-teaser">
    <div class="container">
      <p class="eyebrow">{campaignLabel}</p>
      <h2 class="section-head">Help us reach ${goal.toLocaleString()}.</h2>
      <p class="donate-lede">{home.donate_lede}</p>

      <div class="progress-wrap">
        <div class="progress-bar">
          <div class="progress-fill" style={`width: ${pct}%`}></div>
        </div>
        <div class="progress-stats">
          <span><strong>${raised.toLocaleString()}</strong> raised of ${goal.toLocaleString()} goal</span>
          <span><strong>{donorCount}</strong> donors &middot; <strong>{pct}%</strong> of goal</span>
        </div>
      </div>

      <a href="/donate" class="btn btn-primary">{home.donate_button_label}</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
  }

  .hero-copy h1 {
    margin-block: 0.6rem 1rem;
  }

  .hero-lede {
    font-size: 1.08rem;
    max-width: 60ch;
    margin-bottom: var(--space-md);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  /* Wide hero banner photo */
  .hero-banner-img {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
    margin-top: var(--space-lg);
    box-shadow: var(--shadow-soft);
    max-height: 520px;
  }

  /* ---- Section heading ---- */
  .section-head {
    margin-block: 0.4rem var(--space-lg);
    max-width: 20ch;
  }

  /* ---- Discovery cards ---- */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .card {
    display: block;
    padding: var(--space-md);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .card-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .card h3 {
    margin-bottom: 0.5rem;
  }

  .card-body {
    font-size: 0.95rem;
    margin-bottom: var(--space-sm);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-meta span {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink-muted);
    background: var(--paper-warm);
    border: 1px solid var(--line);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill);
  }

  /* ---- Impact stats ---- */
  .impact {
    background: var(--paper-warm);
    border-block: 1px solid var(--line);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .stat-figure {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 600;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.98rem;
    color: var(--ink-soft);
    margin-top: 0.4rem;
  }

  /* ---- Donation teaser ---- */
  .donate-lede {
    max-width: 54ch;
    margin-bottom: var(--space-lg);
  }

  .progress-wrap {
    margin-bottom: var(--space-lg);
  }

  .progress-bar {
    height: 14px;
    background: var(--accent-soft);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: var(--radius-pill);
  }

  .progress-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.7rem;
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  /* ============ WIDER SCREENS ============ */
  @media (min-width: 720px) {
    .stat-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 920px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
