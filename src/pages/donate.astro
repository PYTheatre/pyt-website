---
/*
  DONATE PAGE  ( /donate )

  Reads three CMS-managed files:
   - donation-campaign.json (progress numbers — also used on home)
   - donor-tiers.json (the tier cards)
   - donate-page.json (intro copy + Soapbox embed URL)
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import campaign from "../content/settings/donation-campaign.json";
import tiers from "../content/settings/donor-tiers.json";
import donatePage from "../content/settings/donate-page.json";

const goal = campaign.goal_amount;
const raised = campaign.raised_amount;
const donorCount = campaign.donor_count;
const campaignLabel = campaign.campaign_label;
const pct = Math.round((raised / goal) * 100);
---

<BaseLayout
  title="Donate — Peninsula Youth Theatre"
  description="Support the next generation of Bay Area performers. Your gift to Peninsula Youth Theatre funds scholarships, productions, and school touring."
>
  <!-- Dark hero with the campaign progress -->
  <section class="donate-hero">
    <div class="container">
      <p class="eyebrow eyebrow-dark">{campaignLabel}</p>
      <h1>{donatePage.intro_heading}</h1>
      <p class="donate-intro">{donatePage.intro_body}</p>

      <div class="progress-wrap">
        <div class="progress-bar">
          <div class="progress-fill" style={`width: ${pct}%`}></div>
        </div>
        <div class="progress-stats">
          <span>
            <strong>${raised.toLocaleString()}</strong> raised of ${goal.toLocaleString()} goal
          </span>
          <span>
            <strong>{donorCount}</strong> donors &middot; <strong>{pct}%</strong> of goal
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation form embed (Soapbox) -->
  <section class="section donate-form-section">
    <div class="container">
      <h2 class="section-head">Make a gift</h2>

      {donatePage.soapbox_embed_url ? (
        <div class="soapbox-embed">
          <iframe
            src={donatePage.soapbox_embed_url}
            title="Donation form"
            loading="lazy"
            allow="payment"
          ></iframe>
        </div>
      ) : (
        <div class="embed-placeholder">
          <p><strong>Donation form coming soon.</strong></p>
          <p>
            We're finalizing our donation platform. In the meantime, please email
            <a href="mailto:info@pytnet.org">info@pytnet.org</a> or call
            <a href="tel:+16509888798">(650) 988-8798</a> to make a gift.
          </p>
          <p class="staff-only">
            <strong>For staff:</strong> Once you have your Soapbox embed URL, paste it
            into <a href="/admin/#/collections/settings/entries/donate-page">/admin → Donate Page</a>.
          </p>
        </div>
      )}

      {donatePage.matching_note && (
        <aside class="matching-callout">
          <p class="matching-eyebrow">Double your gift</p>
          <p>{donatePage.matching_note}</p>
        </aside>
      )}
    </div>
  </section>

  <!-- Donor tiers -->
  <section class="section tiers-section">
    <div class="container">
      <p class="eyebrow">Giving levels</p>
      <h2 class="section-head">Every gift, every level.</h2>

      <ul class="tier-list">
        {tiers.tiers.map((tier) => (
          <li class="tier-card">
            <p class="tier-range">{tier.range}</p>
            <h3>{tier.name}</h3>
            <p class="tier-description">{tier.description}</p>
          </li>
        ))}
      </ul>

      <p class="ein-note">
        Peninsula Youth Theatre is a 501(c)(3) nonprofit. All gifts are tax-deductible to
        the extent allowed by law. EIN 77-0335126.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Dark hero with progress bar ---- */
  .donate-hero {
    background: var(--ink);
    color: #fff;
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .donate-hero h1 {
    color: #fff;
    margin-block: 0.6rem var(--space-md);
  }

  .donate-intro {
    color: rgba(255, 255, 255, 0.85);
    max-width: 60ch;
    font-size: 1.08rem;
    margin-bottom: var(--space-lg);
  }

  .eyebrow-dark {
    color: var(--accent);
  }

  .progress-wrap {
    margin-top: var(--space-md);
  }

  .progress-bar {
    height: 16px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: var(--radius-pill);
  }

  .progress-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.7rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ---- Donation form section ---- */
  .donate-form-section {
    background: var(--paper);
  }

  .section-head {
    margin-block: 0.4rem var(--space-lg);
  }

  .soapbox-embed {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper-warm);
  }

  .soapbox-embed iframe {
    width: 100%;
    min-height: 600px;
    border: 0;
    display: block;
  }

  .embed-placeholder {
    padding: var(--space-lg);
    border: 1px dashed var(--line);
    border-radius: var(--radius);
    background: var(--paper-warm);
  }

  .embed-placeholder p {
    margin-bottom: var(--space-sm);
  }

  .embed-placeholder a {
    color: var(--accent-deep);
    text-decoration: underline;
  }

  .staff-only {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--line);
    font-size: 0.85rem;
    color: var(--ink-muted);
  }

  .matching-callout {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background: var(--accent-soft);
    border-radius: var(--radius);
    border-left: 4px solid var(--accent);
  }

  .matching-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.4rem;
  }

  /* ---- Donor tiers ---- */
  .tiers-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }

  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .tier-card {
    padding: var(--space-md);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .tier-range {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .tier-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .tier-description {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .ein-note {
    margin-top: var(--space-xl);
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-align: center;
  }

  @media (min-width: 720px) {
    .tier-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tier-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
