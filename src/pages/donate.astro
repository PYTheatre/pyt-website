---
/*
  DONATE PAGE  ( /donate )

  Reads three CMS-managed files:
   - donation-campaign.json (progress numbers — also used on home)
   - donor-tiers.json (the tier cards)
   - donate-page.json (intro copy + Soapbox embed URL)
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import campaign from "../content/settings/donation-campaign.json";
import tiers from "../content/settings/donor-tiers.json";
import donatePage from "../content/settings/donate-page.json";

const goal = campaign.goal_amount;
const raised = campaign.raised_amount;
const donorCount = campaign.donor_count;
const campaignLabel = campaign.campaign_label;
const pct = Math.round((raised / goal) * 100);
---

<BaseLayout
  title="Donate — Peninsula Youth Theatre"
  description="Support the next generation of Bay Area performers. Your gift to Peninsula Youth Theatre funds scholarships, productions, and school touring."
>
  <!-- Dark hero with the campaign progress -->
  <section class="donate-hero">
    <div class="container">
      <p class="eyebrow eyebrow-dark">{campaignLabel}</p>
      <h1>{donatePage.intro_heading}</h1>
      <p class="donate-intro">{donatePage.intro_body}</p>

      <div class="progress-wrap">
        <div class="progress-bar">
          <div class="progress-fill" style={`width: ${pct}%`}></div>
        </div>
        <div class="progress-stats">
          <span>
            <strong>${raised.toLocaleString()}</strong> raised of ${goal.toLocaleString()} goal
          </span>
          <span>
            <strong>{donorCount}</strong> donors &middot; <strong>{pct}%</strong> of goal
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation form section (Soapbox) -->
  <section class="section donate-form-section">
    <div class="container">
      <h2 class="section-head">Make a gift</h2>

      {donatePage.soapbox_embed_url ? (
        <!-- Path B: an inline iframe embed, if PYT ever gets one -->
        <div class="soapbox-embed">
          <iframe
            src={donatePage.soapbox_embed_url}
            title="Donation form"
            loading="lazy"
            allow="payment"
          ></iframe>
        </div>
      ) : (
        <!--
          Path A: the donate-now popup trigger.
          Clicking this link triggers the Soapbox popup loaded
          by the script in BaseLayout. The `?sbxdonationsmodal=sbx1`
          parameter is the agreed Soapbox trigger pattern; the link's
          href is `#` because we never want it to actually navigate
          anywhere — the Soapbox script intercepts the click.
        -->
        <div class="donate-now-block">
          <p class="donate-now-blurb">
            Make a one-time gift or set up a recurring donation through our secure
            donation form. Most gifts take less than two minutes.
          </p>
          <a
            href="?sbxdonationsmodal=sbx1"
            class="btn btn-primary btn-donate-now"
          >
            Donate Now
          </a>
          <p class="donate-now-meta">
            Powered by NonprofitSoapbox. Payments processed securely.
          </p>
        </div>
      )}

      {donatePage.matching_note && (
        <aside class="matching-callout">
          <p class="matching-eyebrow">Double your gift</p>
          <p>{donatePage.matching_note}</p>
        </aside>
      )}
    </div>
  </section>

  <!-- Donor tiers -->
  <section class="section tiers-section">
    <div class="container">
      <p class="eyebrow">Giving levels</p>
      <h2 class="section-head">Every gift, every level.</h2>

      <ul class="tier-list">
        {tiers.tiers.map((tier) => (
          <li class="tier-card">
            <p class="tier-range">{tier.range}</p>
            <h3>{tier.name}</h3>
            <p class="tier-description">{tier.description}</p>
          </li>
        ))}
      </ul>

      <p class="ein-note">
        Peninsula Youth Theatre is a 501(c)(3) nonprofit. All gifts are tax-deductible to
        the extent allowed by law. EIN 77-0335126.
      </p>
    </div>
  </section>

  <!-- Sponsorship pointer — sponsorship is a separate giving path -->
  <section class="section sponsor-pointer-section">
    <div class="container sponsor-pointer-inner">
      <p class="eyebrow">For businesses, foundations &amp; major giving</p>
      <h2 class="section-head">Sponsor a show or a season.</h2>
      <p class="sponsor-pointer-body">
        Looking to sponsor a Mainstage production or the full season? Sponsors receive
        public recognition tied to specific shows, including program advertising, lobby
        signage, and on-stage thank-yous. Sponsorship is a separate giving path from
        individual donations.
      </p>
      <div class="sponsor-pointer-buttons">
        <a href="/sponsor#show" class="btn btn-primary">Sponsor a Show</a>
        <a href="/sponsor#season" class="btn btn-outline">Sponsor a Season</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Dark hero with progress bar ---- */
  .donate-hero {
    background: var(--ink);
    color: #fff;
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .donate-hero h1 {
    color: #fff;
    margin-block: 0.6rem var(--space-md);
  }

  .donate-intro {
    color: rgba(255, 255, 255, 0.85);
    max-width: 60ch;
    font-size: 1.08rem;
    margin-bottom: var(--space-lg);
  }

  .eyebrow-dark {
    color: var(--accent);
  }

  .progress-wrap {
    margin-top: var(--space-md);
  }

  .progress-bar {
    height: 16px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: var(--radius-pill);
  }

  .progress-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.7rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ---- Donation form section ---- */
  .donate-form-section {
    background: var(--paper);
  }

  .section-head {
    margin-block: 0.4rem var(--space-lg);
  }

  .soapbox-embed {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper-warm);
  }

  .soapbox-embed iframe {
    width: 100%;
    min-height: 600px;
    border: 0;
    display: block;
  }

  /* ---- Donate Now block (Soapbox popup trigger) ---- */
  .donate-now-block {
    padding: var(--space-lg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-warm);
    text-align: center;
  }

  .donate-now-blurb {
    font-size: 1.02rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-md);
    max-width: 48ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-donate-now {
    font-size: 1.1rem;
    padding: 0.85rem 2.2rem;
  }

  .donate-now-meta {
    margin-top: var(--space-md);
    font-size: 0.8rem;
    color: var(--ink-muted);
  }

  .matching-callout {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background: var(--accent-soft);
    border-radius: var(--radius);
    border-left: 4px solid var(--accent);
  }

  .matching-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.4rem;
  }

  /* ---- Donor tiers ---- */
  .tiers-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }

  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .tier-card {
    padding: var(--space-md);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .tier-range {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .tier-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .tier-description {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .ein-note {
    margin-top: var(--space-xl);
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-align: center;
  }

  @media (min-width: 720px) {
    .tier-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tier-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ---- Sponsorship pointer (bottom of Donate page) ---- */
  .sponsor-pointer-section {
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
  .sponsor-pointer-inner {
    max-width: 64ch;
  }
  .sponsor-pointer-body {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }
  .sponsor-pointer-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
</style>
