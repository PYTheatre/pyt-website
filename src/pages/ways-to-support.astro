---
/*
  WAYS TO SUPPORT PAGE  ( /ways-to-support )
  (formerly /donate — renamed 2026-06-03; URL is now /ways-to-support)
 
  Reads three CMS-managed files:
   - donation-campaign.json (progress numbers — also used on home)
   - donor-tiers.json (the tier cards)
   - donate-page.json (intro copy + hosted Soapbox donation link)
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import campaign from "../content/settings/donation-campaign.json";
import tiers from "../content/settings/donor-tiers.json";
import donatePage from "../content/settings/donate-page.json";
import corporate from "../content/settings/corporate-giving.json";
import recognition from "../content/settings/donor-recognition.json";
 
const goal = campaign.goal_amount;
const raised = campaign.raised_amount;
const donorCount = campaign.donor_count;
const campaignLabel = campaign.campaign_label;
const pct = Math.round((raised / goal) * 100);
// Clamp the visible fill so an over-goal campaign can't overflow the tube.
const fillPct = Math.min(100, Math.max(0, pct));
 
const soapboxDonateUrl =
  donatePage.soapbox_donate_url || "https://pyt.secure.nonprofitsoapbox.com/donate";
 
/*
  SPONSORSHIP — now routes to the hosted Soapbox donation page (NOT Shopify).
  Decided 2026-06-15: sponsorship stays tax-deductible, so both "Sponsor a
  Show" and "Sponsor a Season" buttons point at the general Soapbox donation
  page (same one the Donate button uses). The flexible Soapbox form lets the
  giver enter their own amount and recognition name, so one page serves
  individuals + both sponsorship types. (Reverses the earlier Shopify plan,
  which would not have been tax-deductible.)
  NOTE: the site-wide "Sponsor" buttons on shows/index.astro and
  shows/[slug].astro still need the same swap in a follow-up step.
*/
const sponsorDonateUrl =
  donatePage.soapbox_donate_url || "https://pyt.secure.nonprofitsoapbox.com/donate";
 
// Sponsorship panel text — CMS-editable (Support PYT record), with
// fallbacks so the panel reads correctly before staff fill the fields.
// Eyebrow is fully opt-in: shows only when the field has text (no fallback),
// so clearing it in the CMS removes it.
const sponsorEyebrow = donatePage.sponsor_eyebrow || "";
const sponsorHeading =
  donatePage.sponsor_heading || "Sponsor a show or a season.";
const sponsorShowTitle = donatePage.sponsor_show_title || "Sponsor a Show";
const sponsorShowDescription =
  donatePage.sponsor_show_description ||
  "Back a single Mainstage production and receive recognition tied to that show — program advertising, lobby signage, and on-stage thank-yous.";
const sponsorSeasonTitle = donatePage.sponsor_season_title || "Sponsor a Season";
const sponsorSeasonDescription =
  donatePage.sponsor_season_description ||
  "Support the full season of productions and education programs, with recognition across the whole year of PYT performances.";
// Optional price labels for each sponsor card — shown only when set
// (replaces the old hardcoded "Show-level / Season-level" labels).
const sponsorShowPrice = donatePage.sponsor_show_price || "";
const sponsorSeasonPrice = donatePage.sponsor_season_price || "";
 
/*
  CORPORATE GIVING — also routes to Soapbox (tax-deductible).
  The dedicated corporate Soapbox page does not exist yet, so
  corporate_donate_url is empty for now. While empty, the tier buttons
  render as a non-clickable "Coming soon" pill. Once the PM creates the
  Soapbox corporate page and fills the link in the CMS, the buttons go live.
*/
const corporateDonateUrl = corporate.corporate_donate_url || "";
const corporateLinkLive = corporateDonateUrl.trim().length > 0;
// Optional contact email shown under the corporate intro as a mailto link.
const corporateEmail = (corporate as any).contact_email || "";
 
// Recognition: only show groups that actually have at least one name,
// so empty tiers don't render as bare headings.
const recognitionGroups = (recognition.groups || []).filter(
  (g) => Array.isArray(g.names) && g.names.filter((n) => n && n.trim()).length > 0
);
 
// Giving-levels section headings — CMS-editable (Support PYT record).
// Heading keeps a sensible fallback. The eyebrow is fully OPT-IN: it shows
// only when the field has text. Missing or blank → no eyebrow. (No fallback,
// so clearing it in the CMS genuinely removes it.)
const tiersEyebrow = donatePage.tiers_eyebrow || "";
const tiersHeading = donatePage.tiers_heading || "Every gift, every level.";
---
 
<BaseLayout
  title="Ways to Support — Peninsula Youth Theatre"
  description="Support the next generation of Bay Area performers. Your gift to Peninsula Youth Theatre funds scholarships, productions, and school touring."
>
  <!-- Light hero: campaign progress as a thermometer + Donate button -->
  <section class="section campaign-hero">
    <div class="container">
      <p class="eyebrow">{campaignLabel}</p>
      <h1>{donatePage.intro_heading}</h1>
      <p class="campaign-intro">{donatePage.intro_body}</p>
 
      <div class="thermo-row">
        <!-- Thermometer -->
        <div class="thermo" role="img"
             aria-label={`$${raised.toLocaleString()} raised of $${goal.toLocaleString()} goal, ${pct}% complete`}>
          <div class="thermo-tube">
            <div class="thermo-fill" style={`height: ${fillPct}%`}></div>
          </div>
          <div class="thermo-bulb"></div>
        </div>
 
        <!-- Numbers + Donate button -->
        <div class="thermo-stats">
          <p class="thermo-raised">${raised.toLocaleString()}</p>
          <p class="thermo-goal">raised of ${goal.toLocaleString()} goal</p>
          <p class="thermo-meta">
            <strong>{donorCount}</strong> donors &middot; <strong>{pct}%</strong> of goal
          </p>
          <a
            href={soapboxDonateUrl}
            class="btn btn-primary thermo-donate"
            target="_blank"
            rel="noopener"
          >
            Donate
          </a>
        </div>
      </div>
    </div>
  </section>
 
  <!-- Donor tiers -->
  <section class="section tiers-section">
    <div class="container">
      {tiersEyebrow && <p class="eyebrow">{tiersEyebrow}</p>}
      <h2 class="section-head">{tiersHeading}</h2>
 
      <ul class="tier-list">
        {tiers.tiers.map((tier) => (
          <li class="tier-card">
            <p class="tier-range">{tier.range}</p>
            <h3>{tier.name}</h3>
            <p class="tier-description">{tier.description}</p>
            <a href={soapboxDonateUrl} class="btn btn-primary sponsor-btn" target="_blank" rel="noopener">
              Join
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
 
  <!-- ============ CORPORATE GIVING ============ -->
  <section class="section corporate-section" id="corporate">
    <div class="container">
      {corporate.eyebrow && <p class="eyebrow">{corporate.eyebrow}</p>}
      <h2 class="section-head">{corporate.heading}</h2>
      {corporate.intro && <p class="corporate-intro">{corporate.intro}</p>}
      {corporateEmail && (
        <p class="corporate-contact">
          To discuss corporate giving, email <a href={`mailto:${corporateEmail}`}>{corporateEmail}</a>.
        </p>
      )}
 
      <ul class="tier-list">
        {corporate.tiers.map((tier) => (
          <li class="tier-card">
            <p class="tier-range">{tier.amount}</p>
            <h3>{tier.name}</h3>
            <p class="tier-description">{tier.description}</p>
            {corporateLinkLive ? (
              <a href={corporateDonateUrl} class="btn btn-primary sponsor-btn" target="_blank" rel="noopener">
                Join
              </a>
            ) : (
              <span class="btn btn-primary sponsor-btn is-disabled" aria-disabled="true" role="link" tabindex="-1">
                Coming soon
              </span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>
 
  <!-- ============ SPONSORSHIP ============ -->
  <!--
    Sponsorship routes to the general Soapbox donation page (tax-deductible).
    The per-card "Show-level/Season-level" labels were replaced with an
    OPTIONAL price field (sponsor_show_price / sponsor_season_price) that
    only renders when set — for when price levels are decided.
  -->
  <section class="section sponsor-section" id="sponsor">
    <div class="container">
      {sponsorEyebrow && <p class="eyebrow">{sponsorEyebrow}</p>}
      <h2 class="section-head">{sponsorHeading}</h2>
 
      <ul class="tier-list sponsor-list">
        <li class="tier-card">
          {sponsorShowPrice && <p class="tier-range">{sponsorShowPrice}</p>}
          <h3>{sponsorShowTitle}</h3>
          <p class="tier-description">{sponsorShowDescription}</p>
          <a href={sponsorDonateUrl} class="btn btn-primary sponsor-btn" target="_blank" rel="noopener">
            {sponsorShowTitle}
          </a>
        </li>
 
        <li class="tier-card">
          {sponsorSeasonPrice && <p class="tier-range">{sponsorSeasonPrice}</p>}
          <h3>{sponsorSeasonTitle}</h3>
          <p class="tier-description">{sponsorSeasonDescription}</p>
          <a href={sponsorDonateUrl} class="btn btn-primary sponsor-btn" target="_blank" rel="noopener">
            {sponsorSeasonTitle}
          </a>
        </li>
      </ul>
    </div>
  </section>
 
  <!-- ============ DONOR & SPONSOR RECOGNITION ============ -->
  {recognitionGroups.length > 0 && (
    <section class="section recognition-section" id="recognition">
      <div class="container">
        <p class="eyebrow">{recognition.eyebrow}</p>
        <h2 class="section-head">{recognition.heading}</h2>
        {recognition.intro && <p class="recognition-intro">{recognition.intro}</p>}
 
        <div class="recognition-groups">
          {recognitionGroups.map((group) => (
            <div class="recognition-group">
              <h3 class="recognition-tier">{group.tier_name}</h3>
              <ul class="recognition-names">
                {group.names
                  .filter((n) => n && n.trim())
                  .map((name) => (
                    <li>{name}</li>
                  ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
 
  <!-- 501(c)(3) / EIN note — applies to ALL giving on this page, so it
       sits at the very bottom rather than under the donor tiers. -->
  <section class="section ein-section">
    <div class="container">
      <p class="ein-note">
        Peninsula Youth Theatre is a 501(c)(3) nonprofit. All gifts are tax-deductible to
        the extent allowed by law. EIN 77-0335126.
      </p>
    </div>
  </section>
</BaseLayout>
 
<style>
  /* ---- Light campaign hero with thermometer ---- */
  .campaign-hero {
    background: var(--paper);
  }
 
  .campaign-hero h1 {
    margin-block: 0.6rem var(--space-md);
  }
 
  .campaign-intro {
    color: var(--ink-soft);
    max-width: 60ch;
    font-size: 1.08rem;
    margin-bottom: var(--space-lg);
  }
 
  .section-head {
    margin-block: 0.4rem var(--space-lg);
  }
 
  /* Thermometer + stats laid out side by side (stacks on phones) */
  .thermo-row {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }
 
  .thermo {
    position: relative;
    width: 56px;
    height: 250px;
    flex-shrink: 0;
  }
 
  .thermo-tube {
    position: absolute;
    left: 12px;
    top: 0;
    width: 32px;
    height: 210px;
    border: 3px solid var(--accent);
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    overflow: hidden;
  }
 
  .thermo-fill {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--campaign-fill);
    border-radius: 0 0 var(--radius-pill) var(--radius-pill);
    transition: height 0.4s ease;
  }
 
  .thermo-bulb {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--accent);
  }
 
  .thermo-stats {
    flex: 1;
    min-width: 220px;
  }
 
  .thermo-raised {
    font-size: 2.4rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
    margin: 0;
  }
 
  .thermo-goal {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0.3rem 0 0;
  }
 
  .thermo-meta {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0.6rem 0 0;
  }
 
  .thermo-meta strong {
    color: var(--accent);
  }
 
  .thermo-donate {
    margin-top: var(--space-md);
    font-size: 1.1rem;
    padding: 0.85rem 2.4rem;
  }
 
  /* ---- Donor tiers ---- */
  .tiers-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }
 
  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
 
  .tier-card {
    padding: var(--space-md);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
  }

  /* Push the button to the bottom so cards with longer/shorter text
     still line their buttons up evenly. */
  .tier-card .sponsor-btn {
    margin-top: auto;
    align-self: flex-start;
  }

  /* Keep a little breathing room above the button even when text is short. */
  .tier-card .tier-description {
    margin-bottom: var(--space-md);
  }

  .corporate-contact {
    color: var(--ink-soft);
    font-size: 1rem;
    margin-bottom: var(--space-lg);
  }

  .corporate-contact a {
    color: var(--accent);
    font-weight: 600;
  }
 
  .tier-range {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }
 
  .tier-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }
 
  .tier-description {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
 
  .ein-section {
    border-top: 1px solid var(--line);
  }
 
  .ein-note {
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-align: center;
    margin: 0;
  }
 
  @media (min-width: 720px) {
    .tier-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
 
  @media (min-width: 1024px) {
    .tier-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
 
  /* ---- Sponsorship section (Shopify) ---- */
  .sponsor-section {
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
 
  /* Only two sponsorship cards — cap at 2 columns even on wide screens */
  .sponsor-list {
    max-width: 760px;
  }
 
  /* Disabled "Coming soon" sponsor button */
  .sponsor-btn.is-disabled {
    background: var(--line);
    color: var(--ink-muted);
    cursor: not-allowed;
    pointer-events: none;
    display: inline-block;
  }
 
  @media (min-width: 1024px) {
    .sponsor-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
 
  /* ---- Phone: stack thermometer above the stats ---- */
  @media (max-width: 600px) {
    .thermo-row {
      gap: var(--space-lg);
    }
  }
 
  /* ---- Corporate Giving ---- */
  .corporate-section {
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
 
  .corporate-intro {
    color: var(--ink-soft);
    max-width: 60ch;
    font-size: 1.05rem;
    margin-bottom: var(--space-lg);
  }
 
  /* ---- Donor & sponsor recognition ---- */
  .recognition-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }
 
  .recognition-intro {
    color: var(--ink-soft);
    max-width: 60ch;
    font-size: 1.05rem;
    margin-bottom: var(--space-lg);
  }
 
  .recognition-groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
 
  .recognition-tier {
    font-size: 1.15rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line);
  }
 
  .recognition-names {
    list-style: none;
    padding: 0;
    margin: 0;
  }
 
  .recognition-names li {
    font-size: 1rem;
    color: var(--ink);
    padding: 0.2rem 0;
  }
 
  @media (min-width: 720px) {
    .recognition-groups {
      grid-template-columns: repeat(2, 1fr);
    }
  }
 
  @media (min-width: 1024px) {
    .recognition-groups {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
