---
/*
  WAYS TO SUPPORT PAGE  ( /ways-to-support )
  (formerly /donate — renamed 2026-06-03; URL is now /ways-to-support)
 
  Reads three CMS-managed files:
   - donation-campaign.json (progress numbers — also used on home)
   - donor-tiers.json (the tier cards)
   - donate-page.json (intro copy + hosted Soapbox donation link)
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import campaign from "../content/settings/donation-campaign.json";
import tiers from "../content/settings/donor-tiers.json";
import donatePage from "../content/settings/donate-page.json";
 
const goal = campaign.goal_amount;
const raised = campaign.raised_amount;
const donorCount = campaign.donor_count;
const campaignLabel = campaign.campaign_label;
const pct = Math.round((raised / goal) * 100);
// Clamp the visible fill so an over-goal campaign can't overflow the tube.
const fillPct = Math.min(100, Math.max(0, pct));
 
const soapboxDonateUrl =
  donatePage.soapbox_donate_url || "https://pyt.secure.nonprofitsoapbox.com/donate";
 
/*
  SPONSORSHIP — Shopify (NOT Soapbox).
  Decided 2026-06-03: sponsorship moves to Shopify (reverses earlier
  Soapbox plan). No Shopify store exists yet, so these two links are
  PLACEHOLDERS and the buttons are rendered DISABLED until the real
  Shopify product/collection URLs are supplied. When they arrive:
    1. paste the real URLs below,
    2. set SPONSOR_LINKS_LIVE = true,
  and the buttons activate (they also need the same two URLs swapped
  into the site-wide "Sponsor" buttons — see shows/index.astro and
  shows/[slug].astro).
*/
const SPONSOR_LINKS_LIVE = false;
const SPONSOR_SHOW_URL = "#"; // TODO: Shopify "Sponsor a Show" product URL
const SPONSOR_SEASON_URL = "#"; // TODO: Shopify "Sponsor a Season" product URL
 
// Sponsorship panel text — CMS-editable (Support PYT record), with
// fallbacks so the panel reads correctly before staff fill the fields.
const sponsorEyebrow =
  donatePage.sponsor_eyebrow || "For businesses, foundations & major giving";
const sponsorHeading =
  donatePage.sponsor_heading || "Sponsor a show or a season.";
const sponsorShowTitle = donatePage.sponsor_show_title || "Sponsor a Show";
const sponsorShowDescription =
  donatePage.sponsor_show_description ||
  "Back a single Mainstage production and receive recognition tied to that show — program advertising, lobby signage, and on-stage thank-yous.";
const sponsorSeasonTitle = donatePage.sponsor_season_title || "Sponsor a Season";
const sponsorSeasonDescription =
  donatePage.sponsor_season_description ||
  "Support the full season of productions and education programs, with recognition across the whole year of PYT performances.";
---
 
<BaseLayout
  title="Ways to Support — Peninsula Youth Theatre"
  description="Support the next generation of Bay Area performers. Your gift to Peninsula Youth Theatre funds scholarships, productions, and school touring."
>
  <!-- Light hero: campaign progress as a thermometer + Donate button -->
  <section class="section campaign-hero">
    <div class="container">
      <p class="eyebrow">{campaignLabel}</p>
      <h1>{donatePage.intro_heading}</h1>
      <p class="campaign-intro">{donatePage.intro_body}</p>
 
      <div class="thermo-row">
        <!-- Thermometer -->
        <div class="thermo" role="img"
             aria-label={`$${raised.toLocaleString()} raised of $${goal.toLocaleString()} goal, ${pct}% complete`}>
          <div class="thermo-tube">
            <div class="thermo-fill" style={`height: ${fillPct}%`}></div>
          </div>
          <div class="thermo-bulb"></div>
        </div>
 
        <!-- Numbers + Donate button -->
        <div class="thermo-stats">
          <p class="thermo-raised">${raised.toLocaleString()}</p>
          <p class="thermo-goal">raised of ${goal.toLocaleString()} goal</p>
          <p class="thermo-meta">
            <strong>{donorCount}</strong> donors &middot; <strong>{pct}%</strong> of goal
          </p>
          <a
            href={soapboxDonateUrl}
            class="btn btn-primary thermo-donate"
            target="_blank"
            rel="noopener"
          >
            Donate
          </a>
        </div>
      </div>
 
      {donatePage.matching_note && (
        <aside class="matching-callout">
          <p class="matching-eyebrow">Double your gift</p>
          <p>{donatePage.matching_note}</p>
        </aside>
      )}
    </div>
  </section>
 
  <!-- Donor tiers -->
  <section class="section tiers-section">
    <div class="container">
      <p class="eyebrow">Giving levels</p>
      <h2 class="section-head">Every gift, every level.</h2>
 
      <ul class="tier-list">
        {tiers.tiers.map((tier) => (
          <li class="tier-card">
            <p class="tier-range">{tier.range}</p>
            <h3>{tier.name}</h3>
            <p class="tier-description">{tier.description}</p>
          </li>
        ))}
      </ul>
 
      <p class="ein-note">
        Peninsula Youth Theatre is a 501(c)(3) nonprofit. All gifts are tax-deductible to
        the extent allowed by law. EIN 77-0335126.
      </p>
    </div>
  </section>
 
  <!-- ============ SPONSORSHIP ============ -->
  <!--
    Sponsorship now routes to Shopify (not Soapbox). Two levels only.
    Buttons are disabled until SPONSOR_LINKS_LIVE is true and real
    Shopify URLs are set in the front matter above.
  -->
  <section class="section sponsor-section" id="sponsor">
    <div class="container">
      <p class="eyebrow">{sponsorEyebrow}</p>
      <h2 class="section-head">{sponsorHeading}</h2>
 
      <ul class="tier-list sponsor-list">
        <li class="tier-card">
          <p class="tier-range">Show-level sponsorship</p>
          <h3>{sponsorShowTitle}</h3>
          <p class="tier-description">{sponsorShowDescription}</p>
          {SPONSOR_LINKS_LIVE ? (
            <a href={SPONSOR_SHOW_URL} class="btn btn-primary sponsor-btn" target="_blank" rel="noopener">
              {sponsorShowTitle}
            </a>
          ) : (
            <span class="btn btn-primary sponsor-btn is-disabled" aria-disabled="true" role="link" tabindex="-1">
              Coming soon
            </span>
          )}
        </li>
 
        <li class="tier-card">
          <p class="tier-range">Season-level sponsorship</p>
          <h3>{sponsorSeasonTitle}</h3>
          <p class="tier-description">{sponsorSeasonDescription}</p>
          {SPONSOR_LINKS_LIVE ? (
            <a href={SPONSOR_SEASON_URL} class="btn btn-primary sponsor-btn" target="_blank" rel="noopener">
              {sponsorSeasonTitle}
            </a>
          ) : (
            <span class="btn btn-primary sponsor-btn is-disabled" aria-disabled="true" role="link" tabindex="-1">
              Coming soon
            </span>
          )}
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
 
<style>
  /* ---- Light campaign hero with thermometer ---- */
  .campaign-hero {
    background: var(--paper);
  }
 
  .campaign-hero h1 {
    margin-block: 0.6rem var(--space-md);
  }
 
  .campaign-intro {
    color: var(--ink-soft);
    max-width: 60ch;
    font-size: 1.08rem;
    margin-bottom: var(--space-lg);
  }
 
  .section-head {
    margin-block: 0.4rem var(--space-lg);
  }
 
  /* Thermometer + stats laid out side by side (stacks on phones) */
  .thermo-row {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }
 
  .thermo {
    position: relative;
    width: 56px;
    height: 250px;
    flex-shrink: 0;
  }
 
  .thermo-tube {
    position: absolute;
    left: 12px;
    top: 0;
    width: 32px;
    height: 210px;
    border: 3px solid var(--accent);
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    overflow: hidden;
  }
 
  .thermo-fill {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--campaign-fill);
    border-radius: 0 0 var(--radius-pill) var(--radius-pill);
    transition: height 0.4s ease;
  }
 
  .thermo-bulb {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--accent);
  }
 
  .thermo-stats {
    flex: 1;
    min-width: 220px;
  }
 
  .thermo-raised {
    font-size: 2.4rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
    margin: 0;
  }
 
  .thermo-goal {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0.3rem 0 0;
  }
 
  .thermo-meta {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0.6rem 0 0;
  }
 
  .thermo-meta strong {
    color: var(--accent);
  }
 
  .thermo-donate {
    margin-top: var(--space-md);
    font-size: 1.1rem;
    padding: 0.85rem 2.4rem;
  }
 
  .matching-callout {
    margin-top: var(--space-xl);
    padding: var(--space-md);
    background: var(--accent-soft);
    border-radius: var(--radius);
    border-left: 4px solid var(--accent);
    max-width: 60ch;
  }
 
  .matching-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.4rem;
  }
 
  /* ---- Donor tiers ---- */
  .tiers-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
  }
 
  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
 
  .tier-card {
    padding: var(--space-md);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
 
  .tier-range {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }
 
  .tier-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }
 
  .tier-description {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
 
  .ein-note {
    margin-top: var(--space-xl);
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-align: center;
  }
 
  @media (min-width: 720px) {
    .tier-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
 
  @media (min-width: 1024px) {
    .tier-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
 
  /* ---- Sponsorship section (Shopify) ---- */
  .sponsor-section {
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
 
  /* Only two sponsorship cards — cap at 2 columns even on wide screens */
  .sponsor-list {
    max-width: 760px;
  }
 
  .tier-card .sponsor-btn {
    margin-top: var(--space-md);
  }
 
  /* Disabled "Coming soon" sponsor button */
  .sponsor-btn.is-disabled {
    background: var(--line);
    color: var(--ink-muted);
    cursor: not-allowed;
    pointer-events: none;
    display: inline-block;
  }
 
  @media (min-width: 1024px) {
    .sponsor-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
 
  /* ---- Phone: stack thermometer above the stats ---- */
  @media (max-width: 600px) {
    .thermo-row {
      gap: var(--space-lg);
    }
  }
</style>
 
