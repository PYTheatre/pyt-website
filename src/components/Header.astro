---
/*
  HEADER COMPONENT — sticky top bar.
 
  Contains: logo, main navigation (grouped), a Donate button,
  and a hamburger menu for phones.
 
  NAVIGATION STRUCTURE:
  The top bar has a small number of top-level items. Some are
  plain links; some are "parents" that hold a few related links
  in a dropdown. Parents are themselves clickable (they go to a
  sensible landing page) AND reveal their children on hover or
  keyboard focus — so a parent is never a dead label.
 
  Edit `navGroups` below to change the menu. Each entry is either:
    { label, href }                         → a plain top-level link
    { label, href, children: [ {label,href} ] } → a parent with a dropdown
 
  MOBILE-FIRST: on phones everything collapses into the hamburger
  menu, which lists each group as a labelled section with its
  items beneath (no hover needed — all tappable). On wide screens
  the grouped bar shows and the hamburger disappears.
 
  The EN/ES language toggle will be added in the Spanish
  phase (Phase 4). It's intentionally left out for now.
*/
import Logo from "./Logo.astro";
 
const navGroups = [
  {
    label: "Shows",
    href: "/shows",
    children: [
      { label: "Shows", href: "/shows" },
      { label: "Stories on Stage", href: "/stories-on-stage" },
    ],
  },
  {
    label: "Audition",
    href: "/audition",
    children: [
      { label: "Audition", href: "/audition" },
      { label: "Casting", href: "/casting" },
    ],
  },
  { label: "Classes & Camps", href: "/programs" },
  {
    label: "Shop",
    href: "/shop",
    children: [
      { label: "Shop", href: "/shop" },
      { label: "Rentals", href: "/rentals" },
      { label: "Photos", href: "/photos" },
    ],
  },
  {
    label: "About",
    href: "/about",
    children: [
      { label: "About", href: "/about" },
      { label: "Employment", href: "/employment" },
    ],
  },
  { label: "Support PYT", href: "/ways-to-support" },
];
---
 
<header class="site-header">
  <div class="container header-inner">
    <Logo />
 
    <!-- Desktop / wide-screen navigation -->
    <nav class="nav-wide" aria-label="Main navigation">
      {navGroups.map((group) => (
        group.children ? (
          <div class="nav-group">
            <a href={group.href} class="pill nav-group-trigger" aria-haspopup="true" aria-expanded="false">
              {group.label}
              <svg class="caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="nav-dropdown" role="menu">
              {group.children.map((child) => (
                <a href={child.href} class="nav-dropdown-link" role="menuitem">{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={group.href} class="pill">{group.label}</a>
        )
      ))}
    </nav>
 
    <div class="header-actions">
      <a href="https://pyt.secure.nonprofitsoapbox.com/donate" class="btn btn-primary donate-btn" target="_blank" rel="noopener">Donate</a>
 
      <!-- Hamburger button (phones only) -->
      <button
        class="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="hamburger-btn"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
 
  <!-- Mobile dropdown menu (phones only) -->
  <nav class="nav-mobile" id="mobile-menu" aria-label="Mobile navigation" hidden>
    {navGroups.map((group) => (
      group.children ? (
        <div class="nav-mobile-group">
          <a href={group.href} class="nav-mobile-pill">{group.label}</a>
          {group.children.map((child) => (
            <a href={child.href} class="nav-mobile-sublink">{child.label}</a>
          ))}
        </div>
      ) : (
        <a href={group.href} class="nav-mobile-pill nav-mobile-pill-solo">{group.label}</a>
      )
    ))}
  </nav>
</header>
 
<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
 
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding-block: 0.7rem;
  }
 
  /* Wide-screen nav is hidden on phones by default */
  .nav-wide {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }
 
  .nav-wide .pill {
    padding: 0.45rem 0.85rem;
    font-size: 0.95rem;
    white-space: nowrap;
    font-family: var(--font-heading);
    font-weight: 600;
    background: var(--nav-pill);
    color: var(--nav-pill-text);
    transition: background 0.16s ease;
  }
 
  .nav-wide .pill:hover {
    background: var(--nav-pill-hover);
    color: var(--nav-pill-text);
  }
 
  /* ---- Dropdown groups (desktop) ---- */
  .nav-group {
    position: relative;
  }
 
  .nav-group-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
 
  .caret {
    transition: transform 0.18s ease;
  }
 
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    padding: 0.4rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    /* Hidden until the group is hovered or focused */
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.16s ease, transform 0.16s ease, visibility 0.16s;
    z-index: 60;
  }
 
  /* A small invisible bridge so the cursor can travel from the
     trigger to the dropdown without it closing. */
  .nav-dropdown::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }
 
  .nav-group:hover .nav-dropdown,
  .nav-group:focus-within .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(4px);
  }
 
  .nav-group:hover .caret,
  .nav-group:focus-within .caret {
    transform: rotate(180deg);
  }
 
  .nav-dropdown-link {
    padding: 0.55rem 0.7rem;
    border-radius: 8px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-soft);
    white-space: nowrap;
    transition: background 0.14s ease, color 0.14s ease;
  }
 
  .nav-dropdown-link:hover {
    background: var(--accent-soft);
    color: var(--accent-deep);
  }
 
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
 
  .donate-btn {
    padding: 0.5rem 1.1rem;
    font-size: 0.9rem;
  }
 
  /* Hamburger button */
  .hamburger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0 9px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 10px;
    cursor: pointer;
  }
 
  .hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
 
  /* Animate hamburger into an X when open */
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
 
  /* ---- Mobile dropdown menu ---- */
  .nav-mobile {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--line);
    background: var(--paper);
    padding: 0.6rem;
    /* Cap the menu to the space below the top bar and let it scroll
       internally, so items past the bottom of the screen stay reachable.
       100dvh accounts for the mobile address bar; 100vh is the fallback.
       6rem ≈ the sticky header's own height. */
    max-height: calc(100vh - 6rem);
    max-height: calc(100dvh - 6rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
 
  .nav-mobile[hidden] {
    display: none;
  }
 
  /* Each top-level item (and its sub-rows) sits in a group block. */
  .nav-mobile-group {
    margin-bottom: 0.55rem;
  }

  /* The lilac pill — every top-level item looks like this and is a real link. */
  .nav-mobile-pill {
    display: block;
    padding: 0.7rem 0.85rem;
    border-radius: 12px;
    background: var(--nav-pill);
    color: var(--nav-pill-text);
    font-weight: 600;
    font-size: 0.95rem;
  }

  /* Standalone pills (Classes & Camps, Support PYT) — same pill, own spacing. */
  .nav-mobile-pill-solo {
    margin-bottom: 0.55rem;
  }

  .nav-mobile-pill:hover,
  .nav-mobile-pill:focus-visible {
    background: var(--nav-pill-hover);
    color: var(--nav-pill-text);
  }

  /* Quiet indented sub-rows beneath a pill. */
  .nav-mobile-sublink {
    display: block;
    padding: 0.5rem 0.85rem 0.5rem 1.4rem;
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--ink-soft);
  }

  .nav-mobile-sublink:hover,
  .nav-mobile-sublink:focus-visible {
    color: var(--accent-deep);
  }
  /* ---- Wide screens: show inline nav, hide hamburger ---- */
  @media (min-width: 1000px) {
    .nav-wide {
      display: flex;
    }
    .hamburger {
      display: none;
    }
    .nav-mobile {
      display: none !important;
    }
    .donate-btn {
      padding: 0.55rem 1.3rem;
      font-size: 0.95rem;
    }
  }
</style>
 
<script>
  // Toggle the mobile menu open/closed.
  const btn = document.getElementById("hamburger-btn");
  const menu = document.getElementById("mobile-menu");
 
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!isOpen));
      btn.setAttribute("aria-label", isOpen ? "Open menu" : "Close menu");
      menu.hidden = isOpen;
    });
  }
</script>
