---
/*
  LOGO COMPONENT — placeholder "P" mark.

  WHEN THE REAL LOGO ARRIVES:
  Replace the contents of the <a> below with the real logo
  (an <img> pointing at /logo.svg, or inline SVG). Because
  every page uses THIS component, swapping it here updates
  the logo everywhere at once.
*/
---

<a href="/" class="logo" aria-label="Peninsula Youth Theatre — home">
  <img src="/uploads/pyt-logo.png" alt="PYT" class="logo-mark" width="945" height="324" />
  <span class="logo-text">Peninsula Youth Theatre</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo-mark {
    height: 30px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.02rem;
    color: var(--ink);
    line-height: 1.1;
    /* Hide the wordmark on very small screens to save space;
       the "P" mark alone is enough on a phone. */
    display: none;
  }

  @media (min-width: 520px) {
    .logo-text {
      display: inline;
    }
  }
</style>
