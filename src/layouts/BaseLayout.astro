---
/*
  BASE LAYOUT — the shared shell every page uses.

  It loads the global stylesheet (which loads tokens),
  sets up the document head, and places the Header above
  the page content and the Footer below it.

  Each page passes in its own `title` and optional
  `description` for the browser tab and search engines.
*/
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Peninsula Youth Theatre — outstanding youth theatre in Mountain View, California.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!--
      SOAPBOX DONATION WIDGET LOADER
      ------------------------------
      This script loads the Soapbox donation modal on every page.
      Once loaded, any link or button whose href ends with
      `?sbxdonationsmodal=sbx1` will trigger the donation popup
      instead of navigating. Currently used by the big "Donate Now"
      button on /donate.

      If PYT ever changes Soapbox subdomains, the only line to
      update is the one inside the IIFE below.
    -->
    <script is:inline>
      window.addEventListener("load", function () {
        ((w, d, dm) => {
          const b = d.querySelector("body");
          const s = d.createElement("script");
          s.src = `https://${dm}/component/donations/widget/?popupjs`;
          s.type = "module";
          b.append(s);
        })(window, document, "pyt.secure.nonprofitsoapbox.com");
      });
    </script>
  </body>
</html>
